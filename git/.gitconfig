[user]
    name = Miguel Hernandez
    email = mhernandeztorrez@gmail.com
[init]
    defaultBranch = master
[core]
    editor = vim
    pager = less
    excludesfile = ~/.gitignore_global
    autocrlf = input
[color]
    ui = auto
[credential]
    helper = osxkeychain
[alias]
    c = commit
    ca = commit -a
    cm = commit -m
    cam = commit -am
    d = diff
    dc = diff --cached
    l = log --graph --pretty=format:"%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset" --abbrev-commit

